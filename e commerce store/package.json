{
  "name": "ecommerce-pro",
  "version": "1.0.0",
  "description": "Premium MERN E-Commerce Store",
  "type": "module",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "server": "nodemon backend/server.js",
    "client": "npm run dev --prefix frontend",
    "admin": "npm run dev --prefix admin",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run admin\"",
    "build": "npm run build --prefix frontend && npm run build --prefix admin",
    "data:import": "node backend/seeder.js",
    "data:destroy": "node backend/seeder.js -d"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.2",
    "multer": "^2.0.2",
    "stripe": "^15.3.0"
  },
  "devDependencies": {
    "colors": "^1.4.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
